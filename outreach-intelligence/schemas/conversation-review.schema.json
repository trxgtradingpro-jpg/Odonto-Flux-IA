{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinicflux.ai/schemas/outreach/conversation-review.schema.json",
  "title": "ClinicFlux AI Outreach Conversation Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_id",
    "clinic_name",
    "source",
    "has_website",
    "website_quality",
    "google_rating",
    "review_count",
    "category",
    "city",
    "neighborhood",
    "offer_lane",
    "lead_temperature",
    "cold_outreach_message_count",
    "message_variant",
    "message_sent",
    "clinic_replied",
    "reply_time_minutes",
    "auto_reply_received",
    "human_reply_received",
    "first_human_message_received",
    "first_human_message_at",
    "last_human_reply_at",
    "reply_type",
    "detected_persona",
    "detected_intent",
    "outside_24h_window",
    "template_required",
    "template_used",
    "stop_contact_required",
    "do_not_follow_up",
    "opt_in_status",
    "do_not_contact",
    "max_remaining_cold_messages",
    "analysis_mode",
    "token_efficiency_mode",
    "token_budget_level",
    "should_use_elite_mode",
    "elite_mode_reason",
    "estimated_token_cost_level",
    "data_loading_strategy",
    "large_context_allowed",
    "objection_type",
    "stage_reached",
    "demo_clicked",
    "whatsapp_tested",
    "meeting_booked",
    "proposal_sent",
    "closed_sale",
    "lost_reason",
    "conversation_score",
    "message_quality_score",
    "commercial_risk_score",
    "burn_risk",
    "what_worked",
    "what_failed",
    "missed_opportunities",
    "next_best_action",
    "next_best_message",
    "improvement_notes",
    "tags",
    "microconversions",
    "created_at"
  ],
  "properties": {
    "lead_id": { "type": "string", "minLength": 1 },
    "clinic_name": { "type": "string", "minLength": 1 },
    "source": {
      "type": "string",
      "enum": [
        "google_places",
        "google_maps",
        "local_serp",
        "manual",
        "referral",
        "instagram",
        "public_website",
        "prospecting_list",
        "unknown"
      ]
    },
    "has_website": { "type": "boolean" },
    "website_quality": {
      "type": "string",
      "enum": ["none", "weak", "average", "good", "strong", "unknown"]
    },
    "google_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "review_count": { "type": "integer", "minimum": 0 },
    "category": { "type": "string" },
    "city": { "type": "string" },
    "neighborhood": { "type": "string" },
    "offer_lane": {
      "type": "string",
      "enum": ["website_seo", "clinicflux_ai", "demo", "audit", "responsible", "hybrid", "stop"]
    },
    "lead_temperature": {
      "type": "string",
      "enum": ["cold", "warm", "hot", "very_hot", "lost", "unknown"]
    },
    "cold_outreach_message_count": { "type": "integer", "minimum": 0 },
    "message_variant": { "type": "string" },
    "message_sent": { "type": "string" },
    "clinic_replied": { "type": "boolean" },
    "reply_time_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "auto_reply_received": { "type": "boolean" },
    "human_reply_received": { "type": "boolean" },
    "first_human_message_received": { "type": "boolean" },
    "first_human_message_at": { "type": ["string", "null"], "format": "date-time" },
    "last_human_reply_at": { "type": ["string", "null"], "format": "date-time" },
    "reply_type": {
      "type": "string",
      "enum": [
        "none",
        "auto_reply",
        "human_reply",
        "no_human_reply_after_second_message",
        "asked_source",
        "asked_price",
        "asked_info",
        "permission_to_send",
        "objection",
        "decline"
      ]
    },
    "detected_persona": {
      "type": "string",
      "enum": ["reception", "owner", "dentist", "manager", "automation", "automated", "unknown"]
    },
    "detected_intent": {
      "type": "string",
      "enum": [
        "route_responsible",
        "learn_more",
        "ask_price",
        "request_demo",
        "refuse",
        "not_now",
        "patient_intake",
        "unknown"
      ]
    },
    "outside_24h_window": { "type": "boolean" },
    "template_required": { "type": "boolean" },
    "template_used": { "type": "boolean" },
    "stop_contact_required": { "type": "boolean" },
    "do_not_follow_up": { "type": "boolean" },
    "opt_in_status": {
      "type": "string",
      "enum": [
        "unknown",
        "public_business_contact",
        "explicit_opt_in",
        "human_replied",
        "requested_information",
        "do_not_contact"
      ]
    },
    "do_not_contact": { "type": "boolean" },
    "max_remaining_cold_messages": { "type": "integer", "minimum": 0 },
    "analysis_mode": { "type": "string", "enum": ["economico", "profissional", "elite_300"] },
    "token_efficiency_mode": { "type": "string", "enum": ["economico", "profissional", "elite_300"] },
    "token_budget_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "should_use_elite_mode": { "type": "boolean" },
    "elite_mode_reason": { "type": "string" },
    "estimated_token_cost_level": { "type": "string", "enum": ["low", "medium", "high", "very_high"] },
    "data_loading_strategy": {
      "type": "string",
      "enum": ["minimal", "lead_profile_only", "recent_events_only", "aggregated_summary", "full_campaign_analysis"]
    },
    "large_context_allowed": { "type": "boolean" },
    "objection_type": {
      "type": "string",
      "enum": ["none", "price", "timing", "already_has_system", "no_interest", "not_responsible", "trust", "source", "privacy", "other"]
    },
    "stage_reached": {
      "type": "string",
      "enum": [
        "researched",
        "first_message",
        "replied",
        "responsible_identified",
        "demo_sent",
        "demo_clicked",
        "whatsapp_tested",
        "meeting_booked",
        "proposal_sent",
        "closed_sale",
        "lost"
      ]
    },
    "demo_clicked": { "type": "boolean" },
    "whatsapp_tested": { "type": "boolean" },
    "meeting_booked": { "type": "boolean" },
    "proposal_sent": { "type": "boolean" },
    "closed_sale": { "type": "boolean" },
    "lost_reason": { "type": ["string", "null"] },
    "conversation_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "message_quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "commercial_risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "burn_risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "what_worked": { "type": "array", "items": { "type": "string" } },
    "what_failed": { "type": "array", "items": { "type": "string" } },
    "missed_opportunities": { "type": "array", "items": { "type": "string" } },
    "next_best_action": {
      "type": "string",
      "enum": [
        "send_message",
        "ask_for_responsible",
        "send_demo",
        "send_video",
        "send_summary",
        "book_meeting",
        "wait",
        "follow_up",
        "stop_contact",
        "reply_contextually",
        "send_second_commercial_clarification",
        "use_approved_template_only",
        "stop_contact_or_use_approved_template_only",
        "switch_to_website_offer",
        "switch_to_clinicflux_ai_offer",
        "send_proposal"
      ]
    },
    "next_best_message": { "type": "string" },
    "improvement_notes": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "microconversions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_sent",
        "clinic_replied",
        "asked_source",
        "asked_price",
        "asked_info",
        "responsible_identified",
        "demo_sent",
        "demo_clicked",
        "whatsapp_tested",
        "booking_attempted",
        "meeting_booked",
        "proposal_sent",
        "closed_sale",
        "lost"
      ],
      "properties": {
        "message_sent": { "type": "boolean" },
        "clinic_replied": { "type": "boolean" },
        "asked_source": { "type": "boolean" },
        "asked_price": { "type": "boolean" },
        "asked_info": { "type": "boolean" },
        "responsible_identified": { "type": "boolean" },
        "demo_sent": { "type": "boolean" },
        "demo_clicked": { "type": "boolean" },
        "whatsapp_tested": { "type": "boolean" },
        "booking_attempted": { "type": "boolean" },
        "meeting_booked": { "type": "boolean" },
        "proposal_sent": { "type": "boolean" },
        "closed_sale": { "type": "boolean" },
        "lost": { "type": "boolean" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
