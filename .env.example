# Global
APP_ENV=local
APP_NAME=ClinicFlux AI
APP_TIMEZONE=America/Sao_Paulo
DEFAULT_LOCALE=pt-BR
DEFAULT_CURRENCY=BRL
SENTRY_DSN=

# PostgreSQL
# Opcional no Render: se DATABASE_URL estiver preenchida, ela tem prioridade sobre POSTGRES_*.
DATABASE_URL=
POSTGRES_DB=odontoflux
POSTGRES_USER=odontoflux
POSTGRES_PASSWORD=odontoflux
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]
API_SECRET_KEY=change_me_super_secret
API_ACCESS_TOKEN_EXPIRE_MINUTES=480
API_REFRESH_TOKEN_EXPIRE_MINUTES=43200
API_RATE_LIMIT_PER_MINUTE=120
# Para girar o login bootstrap do /adm, troque e-mail/senha e incremente a versao.
ADM_BOOTSTRAP_EMAIL=clinicfluxai@gmail.com
ADM_BOOTSTRAP_PASSWORD=Ia.123456789
ADM_BOOTSTRAP_VERSION=1
ADM_LOGIN_RATE_LIMIT_PER_MINUTE=8
DEMO_ACCESS_TOKEN_EXPIRE_HOURS=72
DEMO_DEFAULT_EXPIRE_DAYS=21
SALES_OUTREACH_SENDER_TENANT_SLUG=
SALES_OUTREACH_DISPLAY_NAME=Time ClinicFlux AI
SALES_OUTREACH_VIDEO_URL=
BOOTSTRAP_SORRISO_SUL_ON_START=false
SORRISO_SUL_OWNER_EMAIL=owner@sorrisosul.com
SORRISO_SUL_OWNER_PASSWORD=Odonto@123
SORRISO_SUL_OVERWRITE_SETTINGS=true

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=verify-token-dev
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v19.0
WHATSAPP_INLINE_DISPATCH_ON_QUEUE=false

# LLM
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20
AI_AUTORESPONDER_PROMPT_PATH=/app/prompt_editavel.txt

# Audio transcription
AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_TRANSCRIPTION_MODEL=base
AUDIO_TRANSCRIPTION_REFINED_MODEL=medium
AUDIO_TRANSCRIPTION_LANGUAGE=pt
AUDIO_TRANSCRIPTION_DEVICE=cpu
AUDIO_TRANSCRIPTION_COMPUTE_TYPE=int8
AUDIO_TRANSCRIPTION_BEAM_SIZE=1
AUDIO_TRANSCRIPTION_REFINED_BEAM_SIZE=5
AUDIO_TRANSCRIPTION_REFINED_ENABLED=true
AUDIO_TRANSCRIPTION_REFINED_PREPROCESS_ENABLED=true
AUDIO_TRANSCRIPTION_INITIAL_PROMPT=Mensagem de voz em portugues do Brasil enviada pelo WhatsApp.
AUDIO_TRANSCRIPTION_REFINED_FILTER=highpass=f=120, lowpass=f=3800, loudnorm

# Billing
BILLING_PROVIDER=manual
BILLING_SUCCESS_URL=http://localhost:3000/faturamento?checkout=success
BILLING_CANCEL_URL=http://localhost:3000/faturamento?checkout=cancel
BILLING_MANUAL_CHECKOUT_URL=https://billing.clinicfluxai.com.br/checkout
BILLING_CYCLE_DAYS=30
BILLING_OVERDUE_GRACE_DAYS=5
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring
MONITORING_FAILED_JOBS_THRESHOLD=5
MONITORING_ALERT_CHANNELS=email:suporte@clinicfluxai.com.br,whatsapp:+5511999999999

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_ENABLE_DEMO_GUIDE=false
ODONTOFLUX_API_INTERNAL_URL=http://api:8000
WEB_DOCKER_TARGET=dev
WEB_RUNTIME_MODE=production
