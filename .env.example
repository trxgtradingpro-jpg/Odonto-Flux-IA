# Global
APP_ENV=local
APP_NAME=OdontoFlux
APP_TIMEZONE=America/Sao_Paulo
DEFAULT_LOCALE=pt-BR
DEFAULT_CURRENCY=BRL
SENTRY_DSN=

# PostgreSQL
POSTGRES_DB=odontoflux
POSTGRES_USER=odontoflux
POSTGRES_PASSWORD=odontoflux
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]
API_SECRET_KEY=change_me_super_secret
API_ACCESS_TOKEN_EXPIRE_MINUTES=30
API_REFRESH_TOKEN_EXPIRE_MINUTES=10080
API_RATE_LIMIT_PER_MINUTE=120

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=verify-token-dev
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v19.0

# LLM
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20

# Billing
BILLING_PROVIDER=manual
BILLING_SUCCESS_URL=http://localhost:3000/faturamento?checkout=success
BILLING_CANCEL_URL=http://localhost:3000/faturamento?checkout=cancel
BILLING_MANUAL_CHECKOUT_URL=https://billing.odontoflux.com/checkout
BILLING_CYCLE_DAYS=30
BILLING_OVERDUE_GRACE_DAYS=5
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring
MONITORING_FAILED_JOBS_THRESHOLD=5
MONITORING_ALERT_CHANNELS=email:suporte@odontoflux.com,whatsapp:+5511999999999

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
ODONTOFLUX_API_INTERNAL_URL=http://api:8000
WEB_RUNTIME_MODE=production
